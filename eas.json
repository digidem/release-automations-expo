{
  "cli": {
    "version": ">= 14.5.0",
    "appVersionSource": "remote",
    "requireCommit": true
  },
  "build": {
    "base": {
      "android": {
        "image": "latest",
        "node": "20.18.0"
      },
      "ios": {
        "image": "latest",
        "node": "20.18.0"
      }
    },
    "development": {
      "extends": "base",
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "extends": "base",
      "distribution": "internal"
    },
    "production": {
      "extends": "base",
      "autoIncrement": true
    }
  },
  "submit": {
    "production": {}
  }
}
